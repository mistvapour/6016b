{
  "venvPath": ".",
  "venv": "venv",
  "pythonVersion": "3.8",
  "typeCheckingMode": "basic",
  "reportMissingImports": "warning",
  "reportMissingTypeStubs": false,
  "exclude": [
    "**/__pycache__",
    "**/venv",
    "**/.venv",
    "**/node_modules",
    "frontend"
  ],
  "include": [
    "backend",
    "microservices"
  ]
}


